{
  "name": "opencode-projects",
  "version": "0.9.0",
  "description": "Project planning, tracking, and execution plugin for OpenCode with beads integration",
  "type": "module",
  "main": "src/index.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/craiggwilson/nix-config.git",
    "directory": "hdwlinux/packages/opencode-projects-plugin"
  },
  "bugs": {
    "url": "https://github.com/craiggwilson/nix-config/issues"
  },
  "homepage": "https://github.com/craiggwilson/nix-config/tree/main/hdwlinux/packages/opencode-projects-plugin",
  "files": [
    "dist",
    "skills",
    "docs",
    "package.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm --external '@opencode-ai/*'",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "test": "bun test",
    "test:unit": "bun test src/",
    "test:integration": "bun test tests/",
    "test:coverage": "bun test --coverage",
    "test:coverage:lcov": "bun test --coverage --coverage-reporter=lcov",
    "test:ci": "bun test --coverage"
  },
  "keywords": [
    "opencode",
    "projects",
    "planning",
    "beads",
    "issue-tracking"
  ],
  "author": "Craig Wilson",
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.15",
    "@opencode-ai/sdk": "^1.2.15",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/node": "^20.0.0",
    "bun-types": "^1.3.9",
    "typescript": "^5.3.0"
  }
}
